<Page x:Class="Animalerie.WPF.Pages.AnimalAddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ajouter un Animal">

    <ScrollViewer Margin="20">
        <StackPanel>
            <TextBlock Text="Ajouter un nouvel animal" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <Grid>
                <Label Content="Identifiant :" Grid.Row="0"/>
                <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="5"/>

                <Label Content="Nom :" Grid.Row="1"/>
                <TextBox Text="{Binding Nom}" Grid.Row="1" Grid.Column="1" Margin="5"/>

                <Label Content="Type :" Grid.Row="2"/>
                <ComboBox ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}" Grid.Row="2" Grid.Column="1" Margin="5"/>

                <Label Content="Sexe :" Grid.Row="3"/>
                <ComboBox ItemsSource="{Binding Sexes}" SelectedItem="{Binding SelectedSexe}" Grid.Row="3" Grid.Column="1" Margin="5"/>

                <Label Content="Date Naissance :" Grid.Row="4"/>
                <DatePicker SelectedDate="{Binding DateNaissance}" Grid.Row="4" Grid.Column="1" Margin="5"/>

                <Label Content="Couleurs :" Grid.Row="5"/>
                <TextBox Text="{Binding Couleurs}" Grid.Row="5" Grid.Column="1" Margin="5"/>

                <Label Content="Date Stérilisation :" Grid.Row="8"/>
                <DatePicker SelectedDate="{Binding DateSterilisation}" Grid.Row="8" Grid.Column="1" Margin="5"/>

                <Label Content="Raison Entrée :" Grid.Row="9"/>
                <ComboBox ItemsSource="{Binding Raisons}" SelectedItem="{Binding SelectedRaison}" Grid.Row="9" Grid.Column="1" Margin="5"/>

                <Label Content="Date d'entrée :" Grid.Row="10"/>
                <DatePicker SelectedDate="{Binding DateEntree}" Grid.Row="10" Grid.Column="1" Margin="5"/>

                <Label Content="Contact :" Grid.Row="11"/>
                <ComboBox ItemsSource="{Binding Contacts}" SelectedItem="{Binding SelectedContact}" DisplayMemberPath="Nom" Grid.Row="11" Grid.Column="1" Margin="5"/>
            </Grid>

            <Button Content="Enregistrer l'animal" 
                    Command="{Binding SaveCommand}" 
                    Margin="0,20" Height="40" Background="#27AE60" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </ScrollViewer>
</Page>